model ContainerApp {
  id            String   @id @default(uuid())
  name          String   @unique
  image         String
  ports         String   @default("[]") // JSON: PortMapping[]
  envs          String   @default("[]") // JSON: EnvVar[]
  volumes       String   @default("[]") // JSON: VolumeMount[]
  networkNames  String   @default("[]") // JSON: string[]
  labels        String   @default("[]") // JSON: LabelEntry[]
  capAdd        String   @default("[]") // JSON: string[]
  capDrop       String   @default("[]") // JSON: string[]
  restartPolicy String   @default("no")
  hostname      String?
  user          String?
  command       String?
  cpuLimit      Float?
  memoryLimit   String?
  pinnedUrl     String?
  status        String   @default("unknown")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContainerNetwork {
  id        String   @id @default(uuid())
  name      String   @unique
  driver    String   @default("bridge")
  subnet    String?
  gateway   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContainerVolume {
  id         String   @id @default(uuid())
  name       String   @unique
  volumeType String   @default("named")
  sourcePath String?
  placeId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
